<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>신입사원 정보 입력 양식</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            padding: 40px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .header h1 {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #333;
        }
        
        .header p {
            font-size: 14px;
            color: #999;
        }
        
        .section {
            margin-bottom: 40px;
        }
        
        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #333;
            padding-bottom: 12px;
            border-bottom: 2px solid #007bff;
        }
        
        .section-guide {
            font-size: 13px;
            color: #666;
            margin-bottom: 16px;
            font-style: italic;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #333;
        }
        
        .required {
            color: #e74c3c;
        }
        
        input, select, textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
            font-family: inherit;
            transition: border-color 0.2s;
        }
        
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #007bff;
            box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
        }
        
        .table-container {
            overflow-x: auto;
            margin-bottom: 16px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }
        
        th, td {
            padding: 12px;
            text-align: left;
            border: 1px solid #ddd;
        }
        
        th {
            background-color: #f9f9f9;
            font-weight: 600;
            color: #333;
        }
        
        td input {
            margin: 0;
            width: 100%;
        }
        
        button {
            padding: 8px 12px;
            border: 1px solid #ddd;
            background: white;
            border-radius: 6px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
            font-weight: 500;
        }
        
        .btn-add {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        
        .btn-add:hover {
            background: #0056b3;
            border-color: #0056b3;
        }
        
        .btn-remove {
            background: #f8f9fa;
            color: #e74c3c;
            border-color: #e74c3c;
        }
        
        .btn-remove:hover {
            background: #e74c3c;
            color: white;
        }
        
        .btn-submit {
            background: #28a745;
            color: white;
            border-color: #28a745;
            padding: 12px 24px;
            font-size: 15px;
            width: 100%;
            margin-top: 30px;
        }
        
        .btn-submit:hover {
            background: #218838;
            border-color: #218838;
        }
        
        .btn-submit:disabled {
            background: #ccc;
            border-color: #ccc;
            cursor: not-allowed;
        }
        
        input[type="file"] {
            cursor: pointer;
        }
        
        .file-preview {
            margin-top: 8px;
            font-size: 13px;
            color: #007bff;
        }
        
        .alert {
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 16px;
            font-size: 14px;
        }
        
        .alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        
        .alert-error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        
        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        
        @media (max-width: 600px) {
            .row {
                grid-template-columns: 1fr;
            }
            
            .container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>신입사원 정보 입력 양식</h1>
            <p>아래 정보를 입력하여 제출해주세요.</p>
        </div>
        
        <div id="message"></div>
        
        <form id="employeeForm">
            <!-- 기본 정보 섹션 -->
            <div class="section">
                <h2 class="section-title">기본 정보</h2>
                
                <div class="form-group">
                    <label>이름 <span class="required">*</span></label>
                    <input type="text" id="name" placeholder="홍길동" required>
                </div>
                
                <div class="row">
                    <div class="form-group">
                        <label>휴대폰</label>
                        <input type="tel" id="phone" placeholder="010-0000-0000">
                    </div>
                    
                    <div class="form-group">
                        <label>이메일 <span class="required">*</span></label>
                        <input type="email" id="email" placeholder="user@example.com" required>
                    </div>
                </div>
            </div>
            
            <!-- 주소 정보 섹션 -->
            <div class="section">
                <h2 class="section-title">주소 정보</h2>
                
                <div class="form-group">
                    <label>주소</label>
                    <input type="text" id="address" placeholder="서울시 강남구 테헤란로 123">
                </div>
                
                <div class="form-group">
                    <label>등본 첨부</label>
                    <input type="file" id="residenceRegistry" accept=".pdf,.jpg,.jpeg,.png">
                    <div class="file-preview" id="registryPreview"></div>
                </div>
            </div>
            
            <!-- 계좌 정보 섹션 -->
            <div class="section">
                <h2 class="section-title">계좌 정보</h2>
                
                <div class="row">
                    <div class="form-group">
                        <label>은행</label>
                        <input type="text" id="bank" placeholder="예: 국민은행, 우리은행">
                    </div>
                    
                    <div class="form-group">
                        <label>계좌번호</label>
                        <input type="text" id="accountNumber" placeholder="000-000-000000">
                    </div>
                </div>
                
                <div class="form-group">
                    <label>통장사본 첨부</label>
                    <input type="file" id="bankbook" accept=".pdf,.jpg,.jpeg,.png">
                    <div class="file-preview" id="banknookPreview"></div>
                </div>
            </div>
            
            <!-- 비상연락망 섹션 -->
            <div class="section">
                <h2 class="section-title">비상연락망</h2>
                <p class="section-guide">본인 연락처 외 비상 시 연락가능한 배우자/친인척의 연락처 기재 (예: 어머니/010-0000-0000)</p>
                
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 30%">관계</th>
                                <th style="width: 70%">연락처</th>
                            </tr>
                        </thead>
                        <tbody id="emergencyTable">
                            <tr>
                                <td><input type="text" class="emergency-relationship" placeholder="예) 어머니"></td>
                                <td><input type="tel" class="emergency-phone" placeholder="010-0000-0000"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <button type="button" class="btn-add" onclick="addEmergencyRow()">+ 연락처 추가</button>
            </div>
            
            <!-- 유관경력 섹션 -->
            <div class="section">
                <h2 class="section-title">유관경력</h2>
                <p class="section-guide">이전 근무 경력을 입력해주세요. (회사명, 직급, 근무기간 등)</p>
                
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 25%">회사명</th>
                                <th style="width: 20%">직급</th>
                                <th style="width: 20%">입사연월</th>
                                <th style="width: 20%">퇴사연월</th>
                            </tr>
                        </thead>
                        <tbody id="experienceTable">
                            <tr>
                                <td><input type="text" class="experience-company" placeholder="회사명"></td>
                                <td><input type="text" class="experience-position" placeholder="직급"></td>
                                <td><input type="month" class="experience-startMonth"></td>
                                <td><input type="month" class="experience-endMonth"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <button type="button" class="btn-add" onclick="addExperienceRow()">+ 경력 추가</button>
            </div>
            
            <!-- 서류 첨부 섹션 -->
            <div class="section">
                <h2 class="section-title">서류 첨부</h2>
                
                <div class="form-group">
                    <label>졸업증명서</label>
                    <input type="file" id="graduationCertificate" accept=".pdf,.jpg,.jpeg,.png">
                    <div class="file-preview" id="graduationPreview"></div>
                </div>
                
                <div class="form-group">
                    <label>원천징수영수증</label>
                    <input type="file" id="whtCertificate" accept=".pdf,.jpg,.jpeg,.png">
                    <div class="file-preview" id="whtPreview"></div>
                </div>
                
                <div class="form-group">
                    <label>건강보험득실확인서</label>
                    <input type="file" id="healthInsuranceCertificate" accept=".pdf,.jpg,.jpeg,.png">
                    <div class="file-preview" id="healthPreview"></div>
                </div>
            </div>
            
            <button type="submit" class="btn-submit" id="submitBtn">제출하기</button>
        </form>
    </div>
    
    <script>
        const SHEET_URL = 'https://script.google.com/a/macros/theant.kr/s/AKfycbwOGJIONw9Im13of3Z8SXmfa2tpJAqPvWlisHT2y_lz3QVR3iiSkvNx0B1t02Csi_Bg1A/exec';
        
        document.getElementById('residenceRegistry').addEventListener('change', (e) => {
            document.getElementById('registryPreview').textContent = e.target.files[0] ? '✓ ' + e.target.files[0].name + ' 선택됨' : '';
        });
        
        document.getElementById('bankbook').addEventListener('change', (e) => {
            document.getElementById('banknookPreview').textContent = e.target.files[0] ? '✓ ' + e.target.files[0].name + ' 선택됨' : '';
        });
        
        document.getElementById('graduationCertificate').addEventListener('change', (e) => {
            document.getElementById('graduationPreview').textContent = e.target.files[0] ? '✓ ' + e.target.files[0].name + ' 선택됨' : '';
        });
        
        document.getElementById('whtCertificate').addEventListener('change', (e) => {
            document.getElementById('whtPreview').textContent = e.target.files[0] ? '✓ ' + e.target.files[0].name + ' 선택됨' : '';
        });
        
        document.getElementById('healthInsuranceCertificate').addEventListener('change', (e) => {
            document.getElementById('healthPreview').textContent = e.target.files[0] ? '✓ ' + e.target.files[0].name + ' 선택됨' : '';
        });
        
        function addEmergencyRow() {
            const table = document.getElementById('emergencyTable');
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input type="text" class="emergency-relationship" placeholder="예) 어머니"></td>
                <td><input type="tel" class="emergency-phone" placeholder="010-0000-0000"></td>
            `;
            table.appendChild(tr);
        }
        
        function addExperienceRow() {
            const table = document.getElementById('experienceTable');
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input type="text" class="experience-company" placeholder="회사명"></td>
                <td><input type="text" class="experience-position" placeholder="직급"></td>
                <td><input type="month" class="experience-startMonth"></td>
                <td><input type="month" class="experience-endMonth"></td>
            `;
            table.appendChild(tr);
        }
        
        function showMessage(type, text) {
            const msg = document.getElementById('message');
            msg.className = `alert alert-${type}`;
            msg.textContent = text;
            msg.style.display = 'block';
        }
        
        document.getElementById('employeeForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            
            if (!name) {
                showMessage('error', '이름을 입력해주세요.');
                return;
            }
            if (!email) {
                showMessage('error', '이메일을 입력해주세요.');
                return;
            }
            
            const emergencyContacts = [];
            document.querySelectorAll('#emergencyTable tr').forEach(row => {
                const rel = row.querySelector('.emergency-relationship').value;
                const phone = row.querySelector('.emergency-phone').value;
                if (rel || phone) {
                    emergencyContacts.push({ relationship: rel, phone: phone });
                }
            });
            
            const relatedExperience = [];
            document.querySelectorAll('#experienceTable tr').forEach(row => {
                const company = row.querySelector('.experience-company').value;
                const position = row.querySelector('.experience-position').value;
                const startMonth = row.querySelector('.experience-startMonth').value;
                const endMonth = row.querySelector('.experience-endMonth').value;
                if (company || position || startMonth || endMonth) {
                    relatedExperience.push({ company, position, startMonth, endMonth });
                }
            });
            
            const data = {
                timestamp: new Date().toISOString(),
                name: name,
                phone: document.getElementById('phone').value,
                email: email,
                address: document.getElementById('address').value,
                bank: document.getElementById('bank').value,
                accountNumber: document.getElementById('accountNumber').value,
                emergencyContacts: JSON.stringify(emergencyContacts),
                relatedExperience: JSON.stringify(relatedExperience)
            };
            
            try {
                document.getElementById('submitBtn').disabled = true;
                document.getElementById('submitBtn').textContent = '제출 중...';
                
                const response = await fetch(SHEET_URL, {
                    method: 'POST',
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.status === 'success') {
                    showMessage('success', '✓ 정보가 성공적으로 제출되었습니다. HR팀에서 확인 후 연락드리겠습니다.');
                    document.getElementById('employeeForm').reset();
                    document.querySelectorAll('.file-preview').forEach(el => el.textContent = '');
                    
                    setTimeout(() => {
                        document.getElementById('submitBtn').disabled = false;
                        document.getElementById('submitBtn').textContent = '제출하기';
                        document.getElementById('message').style.display = 'none';
                    }, 3000);
                } else {
                    showMessage('error', '제출 중 오류가 발생했습니다: ' + result.message);
                    document.getElementById('submitBtn').disabled = false;
                    document.getElementById('submitBtn').textContent = '제출하기';
                }
            } catch (error) {
                console.error('Error:', error);
                showMessage('error', '제출 중 오류가 발생했습니다. 다시 시도해주세요.');
                document.getElementById('submitBtn').disabled = false;
                document.getElementById('submitBtn').textContent = '제출하기';
            }
        });
    </script>
</body>
</html>
